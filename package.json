{
  "name": "pangch-display-editor",
  "version": "0.0.1",
  "main": "electron-dist/main.js",
  "type": "module",
  "scripts": {
    "dev:renderer": "vite",
    "dev:main": "cross-env NODE_ENV=development nodemon --watch main.ts --watch preload.ts --exec \"tsc -p tsconfig.electron.json && electron .\"",
    "dev": "concurrently --kill-others-on-fail -n \"main,renderer\" \"npm:dev:main\" \"npm:dev:renderer\"",
    "build": "vite build",
    "compile:electron": "tsc -p tsconfig.electron.json",
    "pack": "npm run compile:electron && electron-builder --dir",
    "dist": "npm run build && npm run compile:electron && electron-builder",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^7.0.2",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^43.2.0",
    "electron-builder": "^26.15.3",
    "vite": "^8.1.5",
    "nodemon": "^3.1.14",
    "three": "^0.185.1"
  },
  "dependencies": {
    "axios": "^1.17.0",
    "fflate": "^0.8.3",
    "p-limit": "^7.3.1"
  },
  "author": {
    "name": "Pangch"
  },
  "build": {
    "extraResources": [
      {
        "from": "resources/Pangch-Face.ico",
        "to": "Pangch-Face.ico"
      }
    ],
    "productName": "pde-001",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
  "renderer-dist/**/*",
      "electron-dist/**/*",
      "hardcoded/**/*"
    ],
    "icon": "resources/Pangch-Face.ico",
    "mac": {
      "icon": "resources/Pangch-Face.icns",
      "target": "dmg"
    },
    "win": {
      "icon": "resources/Pangch-Face.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": false,
      "shortcutName": "PDE",
      "artifactName": "PDE-${version}-Setup.exe",
      "uninstallDisplayName": "Panghch Display Editor",
      "installerIcon": "resources/Pangch-Face.ico",
      "uninstallerIcon": "resources/Pangch-Face.ico",
      "installerHeaderIcon": "resources/Pangch-Face.ico"
    }
  }
}
